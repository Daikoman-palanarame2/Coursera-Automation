# ==============================================================================
# ACCCE Configuration Settings
# Copy this file to a new file named ".env" and fill in your keys.
# ==============================================================================

# Your unique access token to use the bot
COURSERA_ENGINE_TOKEN=your_token_here

# The URL of the licensing server (keep this default unless hosted elsewhere)
COURSERA_ENGINE_BACKEND_URL=https://coursera-licensing-service.onrender.com

# Your personal Google Gemini AI API key (used locally to solve quizzes)
GEMINI_API_KEY=your_gemini_api_key_here
